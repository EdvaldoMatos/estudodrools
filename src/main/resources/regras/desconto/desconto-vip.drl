package regras

import com.drools.domain.Cliente

rule "Desconto para cliente VIP"
    agenda-group "descontos"
    salience 30
when
    $cliente : Cliente( tipoCliente != null && tipoCliente.equalsIgnoreCase("VIP") )
then
    $cliente.aplicarMaiorDesconto(15);
    System.out.println("Regra VIP aplicada para: " + $cliente.getNome());
end